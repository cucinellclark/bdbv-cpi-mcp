# Required for ESMFold2 and ESMC embedding tools
# Get a token from https://biohub.ai/developer-console/api-keys
BIOHUB_API_TOKEN=

# Optional: override the Biohub API URL (default: https://biohub.ai)
# BIOHUB_API_URL=https://biohub.ai

# Optional: email for NCBI BLAST API usage (recommended by NCBI guidelines)
# BLAST_EMAIL=your@email.com
